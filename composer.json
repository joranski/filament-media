{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "joranski/filament-media",
    "version": "0.1.2",
    "description": "Filament media uploads with content-hash deduplication, scoped sharing, and captions",
    "keywords": [
        "laravel",
        "filament",
        "media",
        "spatie",
        "deduplication"
    ],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.6",
        "filament/spatie-laravel-media-library-plugin": "^5.0",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/support": "^13.0",
        "livewire/livewire": "^4.0",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Joranski\\FilamentMedia\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Joranski\\FilamentMedia\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Joranski\\FilamentMedia\\FilamentMediaServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "test:compact": "pest --compact --no-coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
